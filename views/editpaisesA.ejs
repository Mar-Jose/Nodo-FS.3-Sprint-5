<!-- sprint 3. tp 3. Etapa 3. Requerimiento 1. -->

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Editar País: <%= paisesE.nombreOfficial %></title>

    <style> 
        body { font-family: sans-serif; background-color: #f0f0f0; padding: 20px; }
        .form-container { max-width: 600px; margin: 0 auto; background: rgb(133, 193, 77); padding: 20px; border: 1px solid #ccc; }
        label { display: block; margin-top: 10px; font-weight: bold; }
        input[type="text"], input[type="number"], textarea { width: 100%; padding: 8px; margin-top: 5px; border: 1px solid #ddd; box-sizing: border-box; }
        .boton-guardar {
            margin-top: 20px;
            padding: 10px 15px;
            background-color: #d0ebff;  
            color: #003366;             
            border: 3px double #003366;  
            border-radius: 6px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .boton-guardar:hover {
            background-color: #003366;   
            color: white;
            transform: scale(1.05);
        }
        .error-message { color: red; margin-top: 5px; }
    </style>
    </head>
<body>


    <div class="form-container">
        <h1>Editar País: <%= paisesE.nombreOfficial %></h1>

        <!-- bloque de errores generales  -->
          <% if (typeof errores !== 'undefined') { %>
                <div style="color: rgb(66, 40, 40); border: 1px solid red; padding: 10px; margin-bottom: 15px;">
                    <p>Corrija los siguientes errores:</p>
                    <ul>
                    <% errores.forEach(error => { %>
                        <li><%= error.msg %></li>
                    <% }); %>
                    </ul>
                </div>
            <% } %>
      
        <form action="/api/paisesA/editar/<%= paisesE._id %>?_method=PUT" method="POST">
                    <!--para html post ya no acepta put-->
    <!--para cumplir con 1 standard se escribe put q lo convierte en post con el método override, el servidor lo interpreta como put-->
    
    <!-- validaciones tipo from, que son las q aparecen en html instantaneamente -->  
   
   <label>Nombre oficial del país:</label>
   <input type="text" name="nombreOfficial" value="<%= paisesE.nombreOfficial %>" required minlength="3" maxlength="90">
   <span style="color: rgb(105, 19, 19)"> Nombre oficial del país es requerido debe tener entre  3-90 caracteres</span>

    <label>Capital:</label>
    <input type="text" name="capital" value="<%= paisesE.capital %>" required minlength="3" maxlength="90">
    <span style="color: rgb(105, 19, 19)"> La capital del país es requerido, debe tener entre 3 hasta 90 letras</span>
    
<!-- 
    <label>Ideoma:</label>
    <input type="text" name="languages" value="<%= paisesE.languages %>" required minlength="3" maxlength="90">
    <span style="color: rgb(105, 19, 19)"> El ideoma es requerido, debe ser un país hispanohablante</span> --> 

    <label>Países limítrofes:</label>
    <input type="text" name="borders" value="<%= Array.isArray(paisesE.borders) ? paisesE.borders.join(' ') : '' %>" required pattern="^([A-Z]{3})(\s[A-Z]{3})*$">
    <span style="color: rgb(105, 19, 19)"> Los países limítrofes tienen un código de 3 letras mayúsculas</span>

    <label>Área:</label>
    <input type="number" name="area" value="<%= paisesE.area %>" required min="0" title="El área del país es requerida">
    <span style="color: rgb(105, 19, 19)"> El área del país debe ser un número positivo</span>

    <label>Población:</label>
    <input type="number" name="population" value="<%= paisesE.population %>" required min="0" step="1" title="La población del país es requerida">
    <span style="color: rgb(105, 19, 19)"> La población del país debe ser un número entero</span>
    
    <label>Zona horaria:</label>
    <input type="text" name="timezones" value="<%= Array.isArray(paisesE.timezones) ? paisesE.timezones.join(', ') : '' %>" required pattern="UTC[+-]\d{1,2}:\d{2}" placeholder="Ej: UTC-03:00">
    <span style="color: rgb(105, 19, 19)"> La zona horaria del país es requerida</span>
    
    <label for="creador"> Creador:</label>
    <input type="text" id="creador" name="creador" value="<%= paisesE.creador %>" required minlength="3" maxlength="90">

    <%# sprint 3. tp 3. Etapa 3. %>
           <button type="submit"
                style="
                    margin-top: 20px;
                    padding: 8px 12px;
                    background-color: #d0ebff;   
                    color: #003366;              
                    border: 2px solid #003366;   
                    border-radius: 5px;
                    font-weight: bold;
                    cursor: pointer;
                    transition: 0.3s;
                "
                onmouseover="
                    this.style.backgroundColor='#003366';
                    this.style.color='white';
                "
                onmouseout="
                    this.style.backgroundColor='#d0ebff';
                    this.style.color='#003366';
                "
                >
                Guardar Cambios
            </button>
            <a href="/api/paisesA" style="margin-left: 15px;">Cancelar</a>

        </form>
    </div>
</body>
</html>