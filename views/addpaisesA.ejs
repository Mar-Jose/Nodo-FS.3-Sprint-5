<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title> Agregar País</title>
    <style> 
        body { font-family: sans-serif; background-color: #f0f0f0; padding: 20px; }
         /*(ajuste ancho de ventana) .form-container { display: inline-block; width: auto; max-width: 600px; background: white; padding: 20px; border: 4px double black; border-radius: 8px; margin: 20px;} */
         .form-container { max-width: 600px; margin: 0 auto; background: rgb(133, 193, 77); padding: 20px; border: 1px solid #ccc; } 
        label { display: block; margin-top: 10px; font-weight: bold; }
        input[type="text"], input[type="number"], textarea { width: 100%; padding: 8px; margin-top: 5px; border: 1px solid #ddd; box-sizing: border-box; }
        button { margin-top: 20px; padding: 10px 15px; background-color: #007bff; color: white; border: none; cursor: pointer; }
    </style>
</head>
<body>
   
    <!-- sprint 3. tp 3. Etapa 3. Requerimiento 5.  -->
   
 <div class="form-container">
  <h2>Agregar Nuevo País</h2>

  <form action="/api/paisesA/agregar" method="POST">

  <!-- validaciones tipo from, que son las q aparecen en html instantaneamente -->   

   <label>Nombre oficial del país:</label>
   <input type="text" name="nombreOfficial" required minlength="3" maxlength="90">
   <span style="color: rgb(105, 19, 19)"> Nombre oficial del país es requerido debe tener entre  3-90 caracteres</span>

    <label>capital del país:</label>
    <input type="text" name="capital" required minlength="3" maxlength="90">
    <span style="color: rgb(105, 19, 19)"> La capital del país es requerido, debe tener entre 3 hasta 90 letras</span>
    
    <label>Países limítrofes:</label>
    <input type="text" name="borders" required minlength="3" maxlength="3">
    <span style="color: rgb(105, 19, 19)"> Los países limítrofes tienen un código de 3 letras mayúsculas</span>

    <label>Área:</label>
    <input type="number" name="area" required min="0">
    <span style="color: rgb(105, 19, 19)"> El área del país debe ser un número positivo</span>

    <label>Población:</label>
    <input type="number" name="population" required min="0" step="1">
    <span style="color: rgb(105, 19, 19)"> La población del país debe ser un número entero</span>

    <label>Zona horaria:</label>
    <input type="text" name="timezones" required pattern="UTC[+-]\d{1,2}:\d{2}" placeholder="Ej: UTC-03:00">
    <span style="color: rgb(105, 19, 19)"> La zona horaria del país es requerida (formato: UTC±hh:mm, Ej: UTC-03:00)</span>

    <label for="creador"> Creador:</label>
    <input type="text" id="creador" name="creador" required minlength="3" maxlength="90">

    <!-- sprint 3. tp 3. Etapa 3. Requerimiento 6: <button type="submit">Guardar Superhéroe</button> -->

   <button type="submit"
   style="
      margin-top: 20px;
      padding: 8px 12px;
      background-color: #dbeecb;   
      color: #2f4f2f;              
      border: 2px solid #2f4f2f;   
      border-radius: 5px;
      font-weight: bold;
      cursor: pointer;
      transition: 0.3s;
   "
   onmouseover="
      this.style.backgroundColor='#2f4f2f';
      this.style.color='white';
   "
   onmouseout="
      this.style.backgroundColor='#dbeecb';
      this.style.color='#2f4f2f';
   "
>
   Guardar País
</button>

   <a href="/api/paisesA" 
   style="
      margin-left: 15px;
      padding: 8px 12px;
      background-color: #ffe6f0;
      color: #800020;
      border: 2px solid #800020;
      border-radius: 5px;
      text-decoration: none;
      font-weight: bold;
      transition: 0.3s;
   "
   onmouseover="this.style.backgroundColor='#800020'; this.style.color='white';"
   onmouseout="this.style.backgroundColor='#ffe6f0'; this.style.color='#800020';"
>
   Volver
</a>   
 </form>
</div>
</body>
</html>